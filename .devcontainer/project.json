{
   "name":"devcontainer",
   "$schema":"../node_modules/nx/schemas/project-schema.json",
   "targets":{
      "publish":{
         "executor":"nx:run-commands",
         "options":{
            "commands":[
               "tsx ./.devcontainer/scripts/compute-devcontainer-hash.ts",
               "tsx ./.devcontainer/scripts/build-devcontainer.ts",
               "tsx ./.devcontainer/scripts/push-devcontainer.ts"
            ],
            "parallel":false
         }
      },
      "test":{
         "executor":"nx:run-commands",
         "options":{
            "commands":[
               {
                  "command":"jest --config jest.config.ts --runInBand",
                  "forwardAllArgs":false
               }
            ]
         }
      }
   }
}