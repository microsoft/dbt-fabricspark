{
  "name": "tools",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "jest --config tools/jest.config.ts --passWithNoTests --runInBand"
      }
    }
  }
}
